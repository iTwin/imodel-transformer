{
  "name": "root",
  "private": true,
  "version": "0.1.0",
  "description": "root of the @itwin/imodel-transformer monorepo",
  "repository": {
    "url": "https://github.com/iTwin/imodel-transformer"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test --filter !transformer-performance-tests",
    "docs": "pnpm -r docs",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "cover": "pnpm -r cover",
    "lint:copyright": "node scripts/copyrightLinter.js",
    "change": "beachball change",
    "check": "beachball check",
    "version-bump": "beachball bump",
    "version-bump-dev": "beachball bump --config beachball.config.dev.js --keep-change-files",
    "publish-packages": "beachball publish",
    "publish-packages-dev": "beachball publish --config beachball.config.dev.js --keep-change-files",
    "pre-commit": "lint-staged",
    "prepare": "husky"
  },
  "license": "MIT",
  "devDependencies": {
    "beachball": "^2.55.1",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{ts,html}": [
      "pnpm lint:copyright --fix",
      "prettier --write -u"
    ]
  },
  "engines": {
    "pnpm": ">=10",
    "npm": "<0",
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "semver": "^7.5.2",
      "axios@0": "^0.32.0",
      "axios@1": "^1.16.0",
      "fast-xml-parser@4": "^4.5.5",
      "fast-xml-parser@5": "^5.5.6",
      "protobufjs@7": "^7.6.1",
      "shell-quote@1": "^1.8.4",
      "@grpc/grpc-js@1": "^1.14.4",
      "ws@7": "^7.5.11",
      "multiparty@4": "^4.3.0",
      "form-data@2": "^2.5.6",
      "form-data@4": "^4.0.6",
      "jws@3": "^3.2.3",
      "jws@4": "^4.0.1",
      "fast-uri@3": "^3.1.2",
      "flatted@3": "^3.4.2",
      "glob@11": "^11.1.0",
      "linkify-it@5": "^5.0.1",
      "picomatch@2": "^2.3.2",
      "minimatch@3": "^3.1.4",
      "minimatch@5": "^5.1.8",
      "minimatch@9": "^9.0.7",
      "path-to-regexp@0": "^0.1.13",
      "playwright@1": "^1.55.1",
      "lodash@4": "^4.18.0"
    },
    "onlyBuiltDependencies": [
      "@bentley/imodeljs-native"
    ]
  },
  "packageManager": "pnpm@10.34.3"
}
