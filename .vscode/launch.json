{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Regression tests",
        "runtimeExecutable": "npm",
        "cwd": "${workspaceFolder}/packages/performance-tests/",
        "runtimeArgs": [
          "run",
          "test-mocha"
        ],
        "skipFiles": [
          "<node_internals>/**"
        ]
      },
      {
        "type": "node",
        "request": "launch",
        "name": "Unit tests",
        "runtimeExecutable": "npm",
        "cwd": "${workspaceFolder}/packages/transformer/",
        "runtimeArgs": [
          "run",
          "test"
        ],
        "skipFiles": [
          "<node_internals>/**"
        ]
      },
      {
        "type": "node",
        "request": "launch",
        "name": "Performance tests",
        "runtimeExecutable": "npm",
        "cwd": "${workspaceFolder}/packages/performance-tests/test",
        "runtimeArgs": [
          "run",
          "test"
        ],
        },
        {
          "type": "node",
          "request": "launch",
          "name": "Quick Perf Benchmarks",
          "program": "${workspaceFolder}/node_modules/.pnpm/mocha@10.8.2/node_modules/mocha/bin/mocha.js",
          "args": [
            "--timeout", "120000",
            "--require", "ts-node/register",
            "test/QuickBenchmark.test.ts"
          ],
          "cwd": "${workspaceFolder}/packages/performance-tests/",
          "skipFiles": [
            "<node_internals>/**"
          ]
        }
    ]
}